<?xml version="1.0" encoding="utf-8"?>
<!--
    item_exercise.xml — CardView for an exercise with nested sets RecyclerView.

    Structure:
    - Exercise name (bold header)
    - Exercise notes (optional, shown below name)
    - Nested RecyclerView for sets (each set shows: set#, reps, weight)
    - Action buttons row: "Add Set" and "Delete Exercise"

    This card is used within the WorkoutDetailActivity's exercise list.
    The nested RecyclerView creates a two-level list without needing
    expandable groups or complex view type logic.

    TODO: Add collapse/expand toggle for the sets list
    TODO: Add exercise drag handle for reordering
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <!-- Exercise header row: name + delete button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Exercise name — the primary identifier -->
            <TextView
                android:id="@+id/textExerciseName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <!-- Delete exercise button — iconographic for compact display -->
            <ImageButton
                android:id="@+id/buttonDeleteExercise"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/delete_exercise"
                android:scaleType="centerInside"
                app:tint="@android:color/darker_gray" />

        </LinearLayout>

        <!-- Exercise notes (optional) — hidden when empty -->
        <TextView
            android:id="@+id/textExerciseNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:visibility="gone" />

        <!-- Divider between header and sets -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_small"
            android:background="@android:color/darker_gray"
            android:alpha="0.2" />

        <!-- Set list header row — column labels for the set data -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/set_header"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reps_header"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/weight_header"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/darker_gray" />

            <!-- Spacer for delete button column -->
            <View
                android:layout_width="36dp"
                android:layout_height="0dp" />

        </LinearLayout>

        <!-- Nested RecyclerView for exercise sets.
             isNestedScrollingEnabled=false so the parent handles scrolling. -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewSets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- "Add Set" button — opens the AddSetDialog -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAddSet"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="@string/add_set"
            android:textAllCaps="false" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
