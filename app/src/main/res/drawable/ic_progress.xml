<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_progress.xml — Vector icon for the "Progress" bottom navigation tab.

    Represents an upward trending line chart — communicates growth and
    improvement, which is exactly what the progress screen tracks.
    Standard 24dp Material Design icon size.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Upward trending line chart icon -->
    <!-- Chart area/axes -->
    <path
        android:fillColor="#000000"
        android:pathData="M3,3 L3,21 L21,21 L21,19 L5,19 L5,3 Z" />

    <!-- Trend line going upward from left to right -->
    <path
        android:fillColor="#000000"
        android:pathData="M7,16 L10,12 L13,14 L19,7 L19,10 L13,16 L10,14 L7,18 Z" />

    <!-- Arrow head at the trend line tip -->
    <path
        android:fillColor="#000000"
        android:pathData="M17,7 L21,7 L21,11 L19,9 L17,7 Z" />

</vector>
